    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ============================================\n// SHOPIFY ORDER PROCESSOR (ENHANCED)\n// ============================================\n\n// 1. Safe Data Extraction\n// We use '||' to provide default values if data is missing, preventing crashes.\nconst orderId = $json.order_id || 'N/A';\nconst orderNumber = $json.order_number || 'N/A';\nconst customerName = $json.customer_name || 'Valued Customer';\nconst customerEmail = $json.customer_email || 'No Email Provided';\nconst totalPrice = $json.total_price || '0.00';\nconst currency = $json.currency || 'USD';\nconst customerPhone = $json.customer_phone || '';\n\n// 2. Process Line Items (Fixes \"items is not iterable\" error)\n// Default to empty array [] if items are missing\nconst lineItems = $json.items || [];\n\nlet itemsSummary = '';\nlet totalItems = 0;\n\n// Check if lineItems is actually an array before looping\nif (Array.isArray(lineItems) && lineItems.length > 0) {\n  \n  lineItems.forEach(item => {\n    const title = item.title || 'Unknown Product';\n    const quantity = item.quantity || 0;\n    const price = item.price || '0.00';\n\n    itemsSummary += `\n      <tr>\n        <td style=\"padding: 10px; border-bottom: 1px solid #eee;\">\n          ${title}\n        </td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #eee; text-align: center;\">\n          ${quantity}\n        </td>\n        <td style=\"padding: 10px; border-bottom: 1px solid #eee;\">\n          ${currency} ${price}\n        </td>\n      </tr>\n    `;\n    totalItems += quantity;\n  });\n\n} else {\n  // Fallback HTML if no items are found\n  itemsSummary = '<tr><td colspan=\"3\" style=\"padding: 10px;\">No items found in this order.</td></tr>';\n}\n\n// 3. Build Shipping Address safely\nconst address1 = $json.shipping_address || '';\nconst city = $json.city || '';\nconst country = $json.country || '';\n\n// Combine and clean up commas if fields are empty\nlet fullAddress = `${address1} ${city} ${country}`.trim();\nif (fullAddress === '') fullAddress = 'No Shipping Address Provided';\n\n// 4. Return Processed Data\nreturn {\n  order_id: orderId,\n  order_number: orderNumber,\n  customer_name: customerName,\n  customer_email: customerEmail,\n  customer_phone: customerPhone,\n  total_price: totalPrice,\n  currency: currency,\n  items_html: itemsSummary,    // Use this in your Gmail node\n  total_items: totalItems,\n  shipping_address: fullAddress,\n  created_at: $json.created_at || new Date().toISOString(),\n  processed_at: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
