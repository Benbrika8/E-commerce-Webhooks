    {
      "parameters": {
        "sendTo": "={{ $json.customer_email }}",
        "subject": "=Order Confirmed  {{ $json.order_number }}",
        "message": "=<!DOCTYPE html> <html> <body style=\"font-family: Arial; padding: 20px; background: #f5f5f5;\">   <div style=\"background: white; padding: 30px; border-radius: 10px;               border-left: 5px solid #2ecc71; max-width: 600px;\">      <h2 style=\"color: #2ecc71;\">✅ Order Confirmed!</h2>      <p>Dear <strong>{{ $json.customer_name }}</strong>,</p>      <p>Thank you for your order! We've received your purchase and         are processing it now.</p>      <div style=\"background: #f8f9fa; padding: 20px; border-radius: 8px;                 margin: 20px 0;\">       <h3 style=\"margin-top: 0;\">Order Details</h3>       <p><strong>Order Number:</strong> #{{ $json.order_number }}</p>       <p><strong>Order Date:</strong> {{ $json.created_at }}</p>       <p><strong>Total:</strong> {{ $json.currency }} {{ $json.total_price }}</p>     </div>      <h3>Items Ordered:</h3>     <table style=\"width: 100%; border-collapse: collapse;\">       <thead>         <tr style=\"background: #f0f0f0;\">           <th style=\"padding: 10px; text-align: left;\">Product</th>           <th style=\"padding: 10px; text-align: left;\">Qty</th>           <th style=\"padding: 10px; text-align: left;\">Price</th>         </tr>       </thead>       <tbody>         {{ $json.items_html }}       </tbody>     </table>      <div style=\"background: #fff3cd; padding: 15px; border-radius: 8px;                 margin: 20px 0;\">       <strong>📦 Shipping Address:</strong><br>       {{ $json.shipping_address }}     </div>      <p>You'll receive another email once your order ships.</p>      <p>Best regards,<br><strong>Store Team</strong></p>   </div> </body> </html>",
        "options": {}
      },
